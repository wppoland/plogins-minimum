#. Plugin Name of the plugin
#: minimum.php
msgid "Minimum - Order Quantity Rules for WooCommerce"
msgstr "Minimum - Reguły ilości zamówień dla WooCommerce"

#. Plugin URI of the plugin
#: minimum.php
msgid "https://plogins.com/minimum/"
msgstr "https://plogins.com/minimum/"

#. Description of the plugin
#: minimum.php
msgid "Set minimum and maximum quantity and order-total rules, enforced at cart and checkout."
msgstr "Ustaw reguły minimalnej i maksymalnej ilości oraz wartości zamówienia, egzekwowane w koszyku i przy zamówieniu."

#. Author of the plugin
#: minimum.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: minimum.php
msgid "https://plogins.com/"
msgstr "https://plogins.com/"

#: minimum.php:55
msgid "Minimum - Order Quantity Rules for WooCommerce requires WooCommerce to be active."
msgstr "Minimum - Reguły ilości zamówień dla WooCommerce wymaga aktywnej wtyczki WooCommerce."

#: src/Rules/Admin.php:61
msgid "Settings"
msgstr "Ustawienia"

#: src/Rules/Admin.php:75
msgid "Minimum - Order Quantity Rules"
msgstr "Minimum - Reguły ilości zamówień"

#: src/Rules/Admin.php:76
msgid "Minimum"
msgstr "Minimum"

#: src/Rules/Admin.php:142
#: src/Rules/Admin.php:339
msgid "Remove"
msgstr "Usuń"

#: src/Rules/Admin.php:143
msgid "Target ID"
msgstr "ID celu"

#: src/Rules/Admin.php:144
#: src/Rules/Admin.php:240
msgid "Scope"
msgstr "Zakres"

#: src/Rules/Admin.php:145
#: src/Rules/Admin.php:242
msgid "Min"
msgstr "Min"

#: src/Rules/Admin.php:146
#: src/Rules/Admin.php:243
msgid "Max"
msgstr "Maks"

#: src/Rules/Admin.php:147
#: src/Rules/Admin.php:244
msgid "Step"
msgstr "Krok"

#: src/Rules/Admin.php:160
msgid "All products (global)"
msgstr "Wszystkie produkty (globalnie)"

#: src/Rules/Admin.php:161
msgid "Specific product"
msgstr "Konkretny produkt"

#: src/Rules/Admin.php:162
msgid "Product category"
msgstr "Kategoria produktów"

#: src/Rules/Admin.php:182
msgid "Define quantity rules and a minimum order total. Rules are enforced when products are added to the cart and again at checkout, with clear notices that block checkout until every rule is satisfied."
msgstr "Zdefiniuj reguły ilości oraz minimalną wartość zamówienia. Reguły są egzekwowane przy dodawaniu produktów do koszyka oraz ponownie przy składaniu zamówienia, z czytelnymi komunikatami, które blokują finalizację zamówienia do czasu spełnienia wszystkich reguł."

#: src/Rules/Admin.php:191
msgid "Enforcement"
msgstr "Egzekwowanie"

#: src/Rules/Admin.php:201
msgid "Enforce quantity and order-total rules."
msgstr "Egzekwuj reguły ilości i wartości zamówienia."

#: src/Rules/Admin.php:203
msgid "Master switch. Turn this off to keep your rules saved but stop enforcing them at the cart and checkout."
msgstr "Przełącznik główny. Wyłącz go, aby zachować zapisane reguły, ale przestać je egzekwować w koszyku i przy zamówieniu."

#: src/Rules/Admin.php:209
msgid "Minimum order total"
msgstr "Minimalna wartość zamówienia"

#: src/Rules/Admin.php:222
msgid "The smallest cart subtotal a customer can check out with. Set to 0 to disable the order-total rule."
msgstr "Najmniejsza wartość koszyka, przy której klient może złożyć zamówienie. Ustaw 0, aby wyłączyć regułę wartości zamówienia."

#: src/Rules/Admin.php:228
msgid "Quantity rules"
msgstr "Reguły ilości"

#: src/Rules/Admin.php:230
msgid "Set a minimum, maximum and step quantity. A specific product rule overrides a category rule, which overrides a global rule. Leave a field at 0 to ignore that constraint."
msgstr "Ustaw minimalną, maksymalną oraz krokową ilość. Reguła dla konkretnego produktu ma pierwszeństwo przed regułą kategorii, a ta przed regułą globalną. Pozostaw pole na wartości 0, aby pominąć dane ograniczenie."

#: src/Rules/Admin.php:235
msgid "No rules yet. Add your first quantity rule below."
msgstr "Brak reguł. Dodaj swoją pierwszą regułę ilości poniżej."

#: src/Rules/Admin.php:241
msgid "Product / Category ID"
msgstr "ID produktu / kategorii"

#: src/Rules/Admin.php:245
msgid "Actions"
msgstr "Akcje"

#: src/Rules/Admin.php:256
msgid "+ Add rule"
msgstr "+ Dodaj regułę"

#: src/Rules/Admin.php:261
msgid "Notice messages"
msgstr "Treści komunikatów"

#: src/Rules/Admin.php:263
msgid "Shown to customers when a rule is not met. Tokens are replaced automatically."
msgstr "Wyświetlane klientom, gdy reguła nie jest spełniona. Symbole zastępcze są podstawiane automatycznie."

#: src/Rules/Admin.php:269
msgid "Below minimum quantity"
msgstr "Poniżej minimalnej ilości"

#: src/Rules/Admin.php:270
msgid "Above maximum quantity"
msgstr "Powyżej maksymalnej ilości"

#: src/Rules/Admin.php:271
msgid "Invalid step quantity"
msgstr "Nieprawidłowa wielokrotność ilości"

#: src/Rules/Admin.php:272
msgid "Below minimum order total"
msgstr "Poniżej minimalnej wartości zamówienia"

#: src/Rules/Admin.php:298
msgid "Rule scope"
msgstr "Zakres reguły"

#: src/Rules/Admin.php:315
msgid "Target product or category ID"
msgstr "ID docelowego produktu lub kategorii"

#: src/Rules/Admin.php:323
msgid "Minimum quantity"
msgstr "Minimalna ilość"

#: src/Rules/Admin.php:329
msgid "Maximum quantity"
msgstr "Maksymalna ilość"

#: src/Rules/Admin.php:335
msgid "Step quantity"
msgstr "Krok ilości"

#. translators: %s: list of available replacement tokens.
#: src/Rules/Admin.php:373
#, php-format
msgid "Available tokens: %s"
msgstr "Dostępne symbole zastępcze: %s"

#: src/Rules/Settings.php:53
msgid "You must buy at least {min} of \"{product}\"."
msgstr "Musisz kupić co najmniej {min} szt. produktu „{product}”."

#: src/Rules/Settings.php:54
msgid "You can buy at most {max} of \"{product}\"."
msgstr "Możesz kupić maksymalnie {max} szt. produktu „{product}”."

#: src/Rules/Settings.php:55
msgid "\"{product}\" must be bought in multiples of {step}."
msgstr "Produkt „{product}” należy kupować w wielokrotnościach {step}."

#: src/Rules/Settings.php:56
msgid "Your order total must be at least {min} (currently {total})."
msgstr "Wartość Twojego zamówienia musi wynosić co najmniej {min} (obecnie {total})."
